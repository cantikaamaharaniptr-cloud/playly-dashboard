# Copy to .env.local for local dev. In production set these in Vercel Project Settings.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Edge function). Set in Vercel: vercel env add DEEPL_API_KEY production
DEEPL_API_KEY=your-deepl-key
